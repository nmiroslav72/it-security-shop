# --- Database (PostgreSQL) ---
# Najlakše: Neon.tech free tier -> kopiraj connection string ovde
DATABASE_URL="postgresql://user:password@host:5432/itsecurity?sslmode=require"

# --- NextAuth ---
# Generiši random string: `openssl rand -base64 32` ili na https://generate-secret.vercel.app/32
AUTH_SECRET="zameni-ovo-sa-pravim-random-stringom"
AUTH_URL="http://localhost:3000"

# --- Admin login (seed) ---
# Lozinka prvog admin korisnika koji se pravi tokom seed-a.
ADMIN_EMAIL="admin@itsecurity.rs"
ADMIN_PASSWORD="promeni-me-odmah"

# --- Payment provider (placeholder) ---
# Kad dobiješ ugovor sa Monri/NestPay, popuni ovde.
PAYMENT_PROVIDER="mock"   # "mock" | "monri" | "nestpay"
PAYMENT_MERCHANT_ID=""
PAYMENT_API_KEY=""
